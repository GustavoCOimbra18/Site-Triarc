rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }
    function existing() { 
      return resource.data; 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'gustavoncoimbra@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }
    
    // Product schema validation
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() > 0 && data.description.size() <= 4000
        && data.price is number && data.price >= 0
        && data.stock is number && data.stock >= 0
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.category is string && data.category.size() > 0;
    }

    // Catalog security
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Store Settings configuration
    match /storeSettings/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Order and customer query validation
    function isValidOrder(data) {
      return data.productId is string && data.productId.size() <= 128
        && data.productName is string && data.productName.size() > 0
        && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 200
        && data.customerEmail is string && data.customerEmail.size() > 0
        && data.status in ['pending', 'contacted', 'completed', 'cancelled']
        && data.totalPrice is number && data.totalPrice >= 0;
    }

    match /orders/{orderId} {
      allow read, list: if true; // High availability for tracking and lists
      allow create: if true; // Guest order placement
      allow update, delete: if isAdmin(); // Only administrator can manage/update orders
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{documentId} {
      allow read, write: if true;
    }

    match /admins/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
