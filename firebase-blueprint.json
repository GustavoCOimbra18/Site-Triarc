{
  "entities": {
    "product": {
      "title": "Product",
      "description": "A luxury item offered in the TRIARC Store",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique key matching document ID" },
        "name": { "type": "string", "description": "Name of the deluxe product" },
        "description": { "type": "string", "description": "Rich text product explanation" },
        "price": { "type": "number", "description": "Retail price in local currency" },
        "currency": { "type": "string", "description": "Currency code e.g. BRL or USD" },
        "imageUrl": { "type": "string", "description": "URL hosted securely on Imgbb" },
        "category": { "type": "string", "description": "High-end product department" },
        "stock": { "type": "number", "description": "Available quantitive stock" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when curated" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when updated" },
        "ownerId": { "type": "string", "description": "ID of the administrator who added the product" }
      },
      "required": ["name", "description", "price", "imageUrl", "category", "stock", "createdAt", "updatedAt"]
    },
    "order": {
      "title": "Order",
      "description": "An inquiry or transaction placed in the TRIARC Store",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique key matching document ID" },
        "productId": { "type": "string", "description": "The referenced product ID" },
        "productName": { "type": "string", "description": "Name of the product in this inquiry" },
        "customerName": { "type": "string", "description": "Lead seeker full name" },
        "customerEmail": { "type": "string", "description": "Lead seeker electronic mail" },
        "customerPhone": { "type": "string", "description": "Lead seeker contact telephone" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed", "cancelled"], "description": "State transition status" },
        "totalPrice": { "type": "number", "description": "Agreed price calculated" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Created at timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Updated at timestamp" }
      },
      "required": ["productId", "productName", "customerName", "customerEmail", "status", "totalPrice", "createdAt", "updatedAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Authorized administrator user account",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Email address of the authorized admin" },
        "role": { "type": "string", "description": "Role, e.g. superadmin or manager" },
        "addedAt": { "type": "string", "format": "date-time", "description": "Timestamp when added" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "product",
      "description": "List of high-end available commodities"
    },
    "orders/{orderId}": {
      "schema": "order",
      "description": "Lead inquires and custom bespoke orders"
    },
    "admins/{email}": {
      "schema": "admin",
      "description": "List of authorized administrator email accounts"
    }
  }
}
